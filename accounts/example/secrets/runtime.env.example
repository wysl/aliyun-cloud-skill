# Aliyun Cloud Monitor - Account Configuration Example
# Copy this file to runtime.env and fill in your values

ALIYUN_ACCOUNT_NAME=your-account-name
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_REGION_IDS=cn-shanghai,cn-beijing

# Optional: Grafana configuration
# GRAFANA_URL=https://your-grafana.example.com
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=your-grafana-password

# Optional: Feishu notification webhook
# FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token